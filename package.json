{
  "name": "daily-tech-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "astro preview",
    "preview": "astro preview",
    "deploy": "astro build && wrangler pages publish dist",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint:check": "oxlint -c oxlintrc.json --tsconfig tsconfig.json --ignore-path .eslintignore",
    "lint:fix": "oxlint -c oxlintrc.json --tsconfig tsconfig.json --ignore-path .eslintignore --fix",
    "lint": "pnpm run lint:check",
    "format:check": "prettier . -c",
    "format:fix": "prettier . -w",
    "format": "pnpm run format:fix",
    "typecheck": "astro check",
    "check": "run-p typecheck format:check lint:check --aggregate-output -l"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.0",
    "@astrojs/mdx": "^3.1.8",
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^4.16.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@prettier/plugin-oxc": "^0.0.4",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^24.0.7",
    "@typescript/native-preview": "7.0.0-dev.20250629.1",
    "lefthook": "^1.11.14",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.3.0",
    "pnpm": "^10.12.4",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.22.0"
  }
}
