---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'ja' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body
    class="m-0 p-0 font-atkinson text-xl leading-relaxed text-custom-black bg-background break-words"
  >
    <Header />
    <main class="w-full max-w-3xl mx-auto px-4 py-12 md:py-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
