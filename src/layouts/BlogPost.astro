---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Layout title={title} description={description}>
  <article
    class="[container-type:inline-size] [container-name:content] w-full max-w-5xl mx-auto p-2 [@container(min-width:480px)]:p-4 [@container(min-width:768px)]:p-6 [@container(min-width:1024px)]:p-8 [@container(min-width:1280px)]:p-10 [@container(min-width:1440px)]:p-12"
  >
    <div
      class="hero-image w-full mb-6 [@container(min-width:480px)]:mb-8 [@container(min-width:768px)]:mb-12 [@container(min-width:1280px)]:mb-16"
    >
      {
        heroImage && (
          <Image
            width={1020}
            height={510}
            src={heroImage}
            alt=""
            class="block mx-auto rounded-lg [@container(min-width:768px)]:rounded-xl shadow-lg aspect-[16/9] [@container(min-width:768px)]:aspect-[21/9] object-cover w-full max-w-4xl"
          />
        )
      }
    </div>
    <div class="prose w-full max-w-4xl mx-auto text-custom-gray-dark">
      <div
        class="title mb-6 [@container(min-width:480px)]:mb-8 [@container(min-width:768px)]:mb-12 py-4 [@container(min-width:768px)]:text-center leading-tight"
      >
        <div
          class="date mb-3 [@container(min-width:480px)]:mb-4 text-custom-gray text-sm [@container(min-width:480px)]:text-base [@container(min-width:768px)]:text-lg"
        >
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <div class="last-updated-on italic mt-1 [@container(min-width:480px)]:mt-2">
                最終更新: <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        <h1
          class="text-2xl [@container(min-width:480px)]:text-3xl [@container(min-width:768px)]:text-4xl [@container(min-width:1024px)]:text-5xl [@container(min-width:1280px)]:text-6xl font-bold mb-3 [@container(min-width:480px)]:mb-4 [@container(min-width:768px)]:mb-6 text-custom-black leading-tight"
        >
          {title}
        </h1>
        <hr class="border-0 border-t border-custom-gray-light" />
      </div>
      <div
        class="content prose-lg text-base [@container(min-width:480px)]:text-lg [@container(min-width:768px)]:text-xl [@container(min-width:1280px)]:text-2xl leading-relaxed"
      >
        <slot />
      </div>
    </div>
  </article>
</Layout>
