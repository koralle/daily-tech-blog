---
import Layout from '../../layouts/Layout.astro';
import TagCard from '../../components/TagCard.astro';
import { getCollection } from 'astro:content';
import { getTagById, type Tag } from '../../data/tags';

// すべての記事を取得してタグを集計
const allPosts = await getCollection('blog');
const tagCounts = new Map<string, number>();

// 各記事のタグをカウント
allPosts.forEach((post) => {
  const tags = post.data.tags || [];
  tags.forEach((tagId) => {
    tagCounts.set(tagId, (tagCounts.get(tagId) || 0) + 1);
  });
});

// タグ情報を配列に変換してソート
const sortedTags = Array.from(tagCounts.entries())
  .map(([tagId, count]) => {
    const tag = getTagById(tagId);
    return tag ? { tag, count } : null;
  })
  .filter((item): item is { tag: Tag; count: number } => item !== null)
  .sort((a, b) => a.tag.displayName.localeCompare(b.tag.displayName, 'ja'));
---

<Layout>
  <div class="w-[960px] max-w-[calc(100%-2em)] mx-auto py-12 px-4">
    <section>
      <h1 class="text-3xl font-bold mb-8 text-center">タグ一覧</h1>

      {
        sortedTags.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {sortedTags.map(({ tag, count }) => (
              <TagCard
                tag={tag}
                postCount={count}
              />
            ))}
          </div>
        ) : (
          <p class="text-center text-gray-600">タグが設定された記事はまだありません。</p>
        )
      }
    </section>
  </div>
</Layout>
