---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getTagById, getAllTagIds } from '../../data/tags';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const postsPerPage = 12;
  const allTagIds = getAllTagIds();

  // すべてのタグを収集
  const tagPostsMap = new Map<string, CollectionEntry<'blog'>[]>();

  // まず有効なタグIDで初期化
  allTagIds.forEach((tagId) => {
    tagPostsMap.set(tagId, []);
  });

  // 各記事のタグを処理
  allPosts.forEach((post) => {
    const tags = post.data.tags || [];
    tags.forEach((tagId) => {
      if (tagPostsMap.has(tagId)) {
        tagPostsMap.get(tagId)!.push(post);
      }
    });
  });

  // 各タグごとにページを生成
  const paths: any[] = [];

  tagPostsMap.forEach((posts, tagId) => {
    // 投稿がない場合でもタグページは生成する
    if (posts.length === 0) {
      paths.push({
        params: { id: tagId },
        props: {
          posts: [],
          tagId,
          currentPage: 1,
          totalPages: 1,
          redirect: false
        }
      });
      return;
    }

    // 投稿を日付順にソート
    const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    const totalPages = Math.ceil(sortedPosts.length / postsPerPage);

    // 各ページのパスを生成
    for (let page = 1; page <= totalPages; page++) {
      const startIndex = (page - 1) * postsPerPage;
      const endIndex = startIndex + postsPerPage;
      const pagePosts = sortedPosts.slice(startIndex, endIndex);

      paths.push({
        params: { id: `${tagId}/${page}` },
        props: {
          posts: pagePosts,
          tagId,
          currentPage: page,
          totalPages,
          redirect: false
        }
      });
    }

    // ページ1へのリダイレクト用パス
    paths.push({
      params: { id: tagId },
      props: {
        redirect: true,
        tagId
      }
    });
  });

  return paths;
}

const { posts, tagId, currentPage, totalPages, redirect } = Astro.props;

// タグIDだけの場合は1ページ目にリダイレクト
if (redirect) {
  return Astro.redirect(`/tags/${tagId}/1`);
}

const tag = getTagById(tagId);
if (!tag) {
  return Astro.redirect('/404');
}
---

<Layout>
  <div class="w-[960px] max-w-[calc(100%-2em)] mx-auto py-12 px-4">
    <section>
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-2">タグ: {tag.displayName}</h1>
        {tag.description && <p class="text-gray-600">{tag.description}</p>}
      </div>

      {
        posts.length === 0 ? (
          <p class="text-center text-gray-600">このタグの記事はまだありません。</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )
      }

      {
        totalPages > 1 && (
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            urlBuilder={(page) => `/tags/${tagId}/${page}`}
          />
        )
      }
    </section>
  </div>
</Layout>
