---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section
    class="[container-type:inline-size] [container-name:grid] w-full max-w-7xl mx-auto p-2 [@container(min-width:480px)]:p-4 [@container(min-width:768px)]:p-6 [@container(min-width:1024px)]:p-8 [@container(min-width:1280px)]:p-10 [@container(min-width:1440px)]:p-12"
  >
    <h1
      class="text-3xl [@container(min-width:480px)]:text-4xl [@container(min-width:768px)]:text-5xl [@container(min-width:1280px)]:text-6xl font-bold mb-6 [@container(min-width:768px)]:mb-8 [@container(min-width:1280px)]:mb-12 text-custom-black [@container(min-width:768px)]:text-center"
    >
      ブログ記事
    </h1>
    <ul
      class="grid [@container(min-width:320px)]:grid-cols-1 [@container(min-width:768px)]:grid-cols-2 [@container(min-width:1024px)]:grid-cols-3 [@container(min-width:1280px)]:grid-cols-4 gap-4 [@container(min-width:480px)]:gap-6 [@container(min-width:768px)]:gap-8 [@container(min-width:1280px)]:gap-10 list-none m-0 p-0"
    >
      {
        posts.map((post, index) => (
          <li
            class={`${index === 0 ? '[@container(min-width:768px)]:col-span-2 [@container(min-width:1024px)]:col-span-3 [@container(min-width:1280px)]:col-span-4' : ''} transition-all duration-200 ease-in-out`}
          >
            <a href={`/blog/${post.id}/`} class="block no-underline group h-full">
              <article class="h-full bg-surface rounded-lg p-4 [@container(min-width:480px)]:p-6 [@container(min-width:768px)]:p-8 border border-custom-gray-light hover:border-accent transition-all duration-200 group-hover:shadow-lg group-hover:shadow-accent/10">
                {post.data.heroImage && (
                  <Image
                    width={720}
                    height={360}
                    src={post.data.heroImage}
                    alt=""
                    class={`mb-3 [@container(min-width:480px)]:mb-4 [@container(min-width:768px)]:mb-6 rounded-lg transition-transform duration-200 group-hover:scale-105 w-full ${index === 0 ? 'aspect-[16/9] [@container(min-width:768px)]:aspect-[21/9]' : 'aspect-[16/9]'} object-cover`}
                  />
                )}
                <div class="flex flex-col justify-between h-full">
                  <div>
                    <h4
                      class={`title m-0 text-custom-black leading-tight group-hover:text-accent transition-colors ${index === 0 ? 'text-xl [@container(min-width:480px)]:text-2xl [@container(min-width:768px)]:text-3xl [@container(min-width:1280px)]:text-4xl' : 'text-lg [@container(min-width:480px)]:text-xl [@container(min-width:768px)]:text-2xl'} mb-2 [@container(min-width:480px)]:mb-3`}
                    >
                      {post.data.title}
                    </h4>
                    {post.data.description && (
                      <p class="text-custom-gray text-sm [@container(min-width:480px)]:text-base [@container(min-width:768px)]:text-lg mb-3 [@container(min-width:480px)]:mb-4 [-webkit-line-clamp:3] [-webkit-box-orient:vertical] [display:-webkit-box] overflow-hidden">
                        {post.data.description}
                      </p>
                    )}
                  </div>
                  <p class="date m-0 text-custom-gray group-hover:text-accent transition-colors text-sm [@container(min-width:480px)]:text-base">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </article>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
