---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="w-full max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-bold mb-8 text-custom-black text-center">ブログ記事</h1>
    <ul class="flex flex-wrap gap-8 list-none m-0 p-0 md:gap-4">
      {
        posts.map((post, index) => (
          <li
            class={`${index === 0 ? 'w-full mb-4 text-center' : 'w-full md:w-[calc(50%-1rem)]'} transition-all duration-200 ease-in-out`}
          >
            <a href={`/blog/${post.id}/`} class="block no-underline group">
              {post.data.heroImage && (
                <Image
                  width={720}
                  height={360}
                  src={post.data.heroImage}
                  alt=""
                  class={`mb-2 rounded-xl transition-shadow duration-200 group-hover:shadow-lg ${index === 0 ? 'w-full' : ''}`}
                />
              )}
              <h4
                class={`title m-0 text-custom-black leading-tight group-hover:text-accent transition-colors ${index === 0 ? 'text-4xl md:text-5xl' : 'text-xl md:text-2xl'}`}
              >
                {post.data.title}
              </h4>
              <p class="date m-0 text-custom-gray group-hover:text-accent transition-colors">
                <FormattedDate date={post.data.pubDate} />
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
