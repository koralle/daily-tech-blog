---
import { Icon } from 'astro-icon/components';
import type { TagMetadata } from '../data/tagMetadata';

interface Props {
  tag: TagMetadata;
  postCount?: number;
}

const { tag, postCount } = Astro.props;
---

<a
  href={`/tags/${encodeURIComponent(tag.name)}`}
  class="block p-6 bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow border border-gray-200"
>
  <div class="flex items-center gap-4">
    <!--
    {
      tag.icon && (
        <div class="text-4xl text-gray-700">
          <Icon name={tag.icon} />
        </div>
      )
    }
    -->
    <div class="flex-1">
      <h3 class="text-xl font-semibold text-gray-900 mb-1">{tag.name}</h3>
      {tag.description && <p class="text-sm text-gray-600 mb-2">{tag.description}</p>}
      {postCount !== undefined && <p class="text-sm text-gray-500">{postCount} 件の記事</p>}
    </div>
  </div>
</a>
