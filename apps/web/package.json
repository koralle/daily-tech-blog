{
  "name": "@daily-tech-blog/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "prepare": "panda codegen",
    "build": "astro build",
    "start": "astro preview",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run lint:check",
    "format:check": "prettier . -c --config .prettierrc.mjs",
    "format:fix": "prettier . -w --config .prettierrc.mjs",
    "format": "pnpm run format:fix",
    "typecheck": "astro check --tsconfig tsconfig.json",
    "check": "run-p typecheck format:check lint:check --aggregate-output -l",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@astrojs/cloudflare": "catalog:astro",
    "@astrojs/mdx": "catalog:astro",
    "@astrojs/rss": "catalog:astro",
    "@astrojs/sitemap": "catalog:astro",
    "astro": "catalog:astro",
    "dayjs": "catalog:util",
    "kiso.css": "catalog:css",
    "preact": "catalog:preact",
    "sharp": "catalog:util"
  },
  "devDependencies": {
    "@astrojs/check": "catalog:astro",
    "@astrojs/preact": "catalog:astro",
    "@astrojs/ts-plugin": "catalog:astro",
    "@pandacss/dev": "catalog:css",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/preact-vite": "catalog:storybook",
    "@types/node": "catalog:runtime",
    "oxlint": "catalog:oxlint",
    "pnpm": "catalog:pnpm",
    "prettier-plugin-astro": "catalog:format",
    "react": "catalog:react",
    "storybook": "catalog:storybook",
    "typescript": "catalog:runtime"
  }
}
